{
  "rewrites": [
    {
      "source": "/ingest/static/:path*",
      "destination": "https://us-assets.i.posthog.com/static/:path*"
    },
    {
      "source": "/api/ingest/:path*",
      "destination": "/api/ingest"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
